{
  "name": "gogor-games",
  "version": "1.0.1",
  "private": true,
  "type": "module",
  "main": "expo-router/entry",
  "scripts": {
    "dev": "concurrently -k \"pnpm dev:server\" \"pnpm dev:metro\"",
    "dev:server": "cross-env NODE_ENV=development tsx watch server/_core/index.ts",
    "dev:metro": "npx expo start --dev-client --port ${EXPO_PORT:-8081}",
    "dev:web": "concurrently -k \"pnpm dev:server\" \"pnpm dev:metro:web\"",
    "dev:metro:web": "npx expo start --web --port ${EXPO_PORT:-8081}",
    "build": "esbuild server/_core/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "start": "NODE_ENV=production node dist/index.js",
    "check": "tsc --noEmit",
    "lint": "expo lint",
    "format": "prettier --write .",
    "test": "vitest run",
    "db:push": "drizzle-kit generate && drizzle-kit migrate",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "qr": "node scripts/generate_qr.mjs",
    "build:dev:ios": "eas build --platform ios --profile development",
    "build:dev:android": "eas build --platform android --profile development",
    "build:internal:ios": "eas build --platform ios --profile preview",
    "build:internal:android": "eas build --platform android --profile preview",
    "build:internal": "eas build --platform all --profile preview",
    "release:test:ios": "eas build --platform ios --profile production --auto-submit-with-profile test",
    "release:test:android": "eas build --platform android --profile production --auto-submit-with-profile test",
    "release:test": "eas build --platform all --profile production --auto-submit-with-profile test",
    "release:production:ios": "eas build --platform ios --profile production --auto-submit",
    "release:production:android": "eas build --platform android --profile production --auto-submit",
    "release:production": "eas build --platform all --profile production --auto-submit"
  },
  "dependencies": {
    "@expo/dom-webview": "^56.0.5",
    "@expo/metro-runtime": "~56.0.15",
    "@expo/vector-icons": "^15.1.1",
    "@hangtime/grip-connect-react-native": "^0.13.1",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@tanstack/react-query": "^5.101.0",
    "@trpc/client": "^11.18.0",
    "@trpc/react-query": "^11.18.0",
    "@trpc/server": "^11.18.0",
    "axios": "^1.18.1",
    "buffer": "^6.0.3",
    "clsx": "^2.1.1",
    "cookie": "^1.1.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "expo": "~56.0.12",
    "expo-asset": "^56.0.17",
    "expo-audio": "~56.0.12",
    "expo-build-properties": "~56.0.19",
    "expo-constants": "~56.0.18",
    "expo-dev-client": "~56.0.20",
    "expo-font": "~56.0.7",
    "expo-haptics": "~56.0.3",
    "expo-image": "~56.0.11",
    "expo-keep-awake": "~56.0.3",
    "expo-linking": "~56.0.14",
    "expo-localization": "~56.0.6",
    "expo-notifications": "~56.0.18",
    "expo-router": "~56.2.11",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.6",
    "expo-system-ui": "~56.0.5",
    "expo-web-browser": "~56.0.5",
    "express": "^5.2.1",
    "i18next": "^26.3.1",
    "jose": "^6.2.3",
    "lightningcss": "^1.32.0",
    "mysql2": "^3.22.5",
    "nativewind": "^4.2.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-i18next": "^17.0.8",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.2",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.8.3",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@babel/traverse": "^7.29.7",
    "@expo/ngrok": "^4.1.3",
    "@types/express": "^5.0.6",
    "@types/node": "^22.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "~19.2.17",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.27.7",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~56.0.4",
    "prettier": "^3.8.4",
    "qrcode": "^1.5.4",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.22.4",
    "typescript": "~6.0.3",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@10.34.1"
}
