{
  "name": "app-template",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "expo-router/entry",
  "scripts": {
    "dev": "concurrently -k \"pnpm dev:server\" \"pnpm dev:metro\"",
    "dev:server": "cross-env NODE_ENV=development tsx watch server/_core/index.ts",
    "dev:metro": "npx expo start --dev-client --port ${EXPO_PORT:-8081}",
    "dev:web": "concurrently -k \"pnpm dev:server\" \"pnpm dev:metro:web\"",
    "dev:metro:web": "npx expo start --web --port ${EXPO_PORT:-8081}",
    "build": "esbuild server/_core/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "start": "NODE_ENV=production node dist/index.js",
    "check": "tsc --noEmit",
    "lint": "expo lint",
    "format": "prettier --write .",
    "test": "vitest run",
    "db:push": "drizzle-kit generate && drizzle-kit migrate",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "qr": "node scripts/generate_qr.mjs",
    "preview:ios": "eas build --platform ios --profile preview",
    "preview:android": "eas build --platform android --profile preview",
    "preview": "eas build --platform all --profile preview",
    "test:ios": "eas build --platform ios --profile preview",
    "test:android": "eas build --platform android --profile preview",
    "test:device": "eas build --platform all --profile preview",
    "release:ios": "eas build --platform ios --profile production --auto-submit",
    "release:android": "eas build --platform android --profile production --auto-submit",
    "release": "eas build --platform all --profile production --auto-submit"
  },
  "dependencies": {
    "@expo/metro-runtime": "~55.0.11",
    "@expo/vector-icons": "^15.1.1",
    "@hangtime/grip-connect-react-native": "^0.13.0",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/bottom-tabs": "7.15.5",
    "@react-navigation/elements": "^2.9.19",
    "@react-navigation/native": "7.1.33",
    "@tanstack/react-query": "^5.100.14",
    "@trpc/client": "^11.17.0",
    "@trpc/react-query": "^11.17.0",
    "@trpc/server": "^11.17.0",
    "axios": "^1.16.1",
    "buffer": "^6.0.3",
    "clsx": "^2.1.1",
    "cookie": "^1.1.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "expo": "^55.0.26",
    "expo-asset": "^55.0.17",
    "expo-audio": "~55.0.14",
    "expo-build-properties": "~55.0.14",
    "expo-constants": "~55.0.16",
    "expo-dev-client": "~55.0.35",
    "expo-font": "~55.0.8",
    "expo-haptics": "~55.0.14",
    "expo-image": "~55.0.11",
    "expo-keep-awake": "~55.0.8",
    "expo-linking": "~55.0.15",
    "expo-localization": "~55.0.15",
    "expo-notifications": "~55.0.23",
    "expo-router": "~55.0.16",
    "expo-secure-store": "~55.0.14",
    "expo-splash-screen": "~55.0.21",
    "expo-status-bar": "~55.0.6",
    "expo-symbols": "~55.0.9",
    "expo-system-ui": "~55.0.18",
    "expo-web-browser": "~55.0.16",
    "express": "^5.2.1",
    "i18next": "^26.3.0",
    "jose": "^6.2.3",
    "lightningcss": "^1.32.0",
    "mysql2": "^3.22.4",
    "nativewind": "^4.2.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-i18next": "^17.0.8",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.1",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.7.4",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@babel/traverse": "^7.29.7",
    "@expo/ngrok": "^4.1.3",
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.19",
    "@types/qrcode": "^1.5.6",
    "@types/react": "~19.2.15",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.27.7",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~55.0.1",
    "prettier": "^3.8.3",
    "qrcode": "^1.5.4",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.22.3",
    "typescript": "~5.9.3",
    "vitest": "^4.1.7"
  },
  "packageManager": "pnpm@10.33.2"
}
